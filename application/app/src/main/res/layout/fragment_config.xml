<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/white_bg">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="24dp">

        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_revert"
                android:contentDescription="@string/back_button_description"
                app:tint="@color/text_main" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EIA.AI"
                android:textColor="@color/text_main"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginStart="16dp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Konfiguracja sieci"
            android:textColor="@color/text_main"
            android:textSize="32sp"
            android:textStyle="bold"
            android:paddingHorizontal="24dp"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/topBar" />

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ustawienia parametrów połączenia dla urządzenia pomiarowego"
            android:textColor="@color/text_muted"
            android:textSize="14sp"
            android:paddingHorizontal="24dp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvTitle" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cardSelectedWifi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/card_bg"
            app:strokeColor="@color/border_gray"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitle">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_dialog_info"
                    android:contentDescription="@string/info_icon_description"
                    app:tint="@color/text_main" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="WYBRANA SIEĆ"
                        android:textColor="@color/text_muted"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvSelectedWifiName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="EIA_Technical_Industrial_01"
                        android:textColor="@color/text_main"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/lblPassword"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HASŁO SIECI"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/cardSelectedWifi"
            app:layout_constraintStart_toStartOf="parent"/>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/inputLayoutPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="8dp"
            app:hintEnabled="false"
            app:passwordToggleEnabled="true"
            app:passwordToggleTint="@color/text_muted"
            app:boxBackgroundMode="none"
            app:layout_constraintTop_toBottomOf="@id/lblPassword">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:inputType="textPassword"
                android:paddingHorizontal="16dp"
                android:textSize="14sp"
                android:textColor="@color/text_main" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/lblIpType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PRZYPISANIE ADRESU IP"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/inputLayoutPassword"
            app:layout_constraintStart_toStartOf="parent"/>

        <LinearLayout
            android:id="@+id/toggleIpGroup"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/lblIpType">

            <android.widget.Button
                android:id="@+id/btnStaticIp"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Statyczne IP"
                android:textAllCaps="false"
                android:textColor="@color/white_bg"
                android:textStyle="bold"
                android:background="@drawable/bg_toggle_left" />

            <android.widget.Button
                android:id="@+id/btnDhcp"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="DHCP"
                android:textAllCaps="false"
                android:textColor="@color/text_muted"
                android:background="@drawable/bg_toggle_right" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutStaticFields"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/toggleIpGroup">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ADRES IP"
                        android:textSize="10sp"
                        android:textStyle="bold"/>
                    <EditText
                        android:id="@+id/etStaticIpAddress"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="6dp"
                        android:text="192.168.1.100"
                        android:textColor="@color/text_main"
                        android:textSize="14sp"
                        android:paddingHorizontal="12dp"
                        android:inputType="text"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MASKA"
                        android:textSize="10sp"
                        android:textStyle="bold"/>
                    <EditText
                        android:id="@+id/etStaticNetmask"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="6dp"
                        android:text="255.255.255.0"
                        android:textColor="@color/text_main"
                        android:textSize="14sp"
                        android:paddingHorizontal="12dp"
                        android:inputType="text"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BRAMA DOMYŚLNA"
                    android:textSize="10sp"
                    android:textStyle="bold"/>
                <EditText
                    android:id="@+id/etStaticGateway"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="6dp"
                    android:text="192.168.1.1"
                    android:textColor="@color/text_main"
                    android:textSize="14sp"
                    android:paddingHorizontal="12dp"
                    android:inputType="text"/>
            </LinearLayout>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubmit"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="40dp"
            android:text="ZATWIERDŹ I POŁĄCZ"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/white_bg"
            app:backgroundTint="@color/black_main"
            app:cornerRadius="12dp"
            app:layout_constraintTop_toBottomOf="@id/layoutStaticFields" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>